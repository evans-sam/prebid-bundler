{
  "name": "prebid-bundler",
  "version": "0.2.0",
  "description": "Build and serve custom Prebid.js bundles with Docker support",
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "bin": {
    "prebid-bundler": "./bin/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./commands": "./src/commands/index.ts",
    "./docker/*": "./docker/*",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "src",
    "docker",
    "checkout.ts"
  ],
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "checkout": "bun run checkout.ts",
    "test": "bun test",
    "docker:build": "bun run bin/cli.ts build",
    "prepublishOnly": "bun test"
  },
  "keywords": [
    "prebid",
    "prebid.js",
    "header-bidding",
    "advertising",
    "bundler",
    "docker"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/semver": "^7.7.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "semver": "^7.7.3"
  }
}
